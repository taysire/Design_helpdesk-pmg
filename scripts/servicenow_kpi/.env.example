# ── Microsoft Graph / SharePoint (source principale) ─────────────────────────
# Liste Tickets : https://pmgqc.sharepoint.com/sites/ServiceNow/Lists/Tickets
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret

GRAPH_SITE_HOST=pmgqc.sharepoint.com
GRAPH_SITE_PATH=/sites/ServiceNow
GRAPH_LIST_NAME=Tickets

# Override manuel de période (optionnel — sinon calcul auto chaque lundi)
# SNOW_PERIOD_START=2026-06-01
# SNOW_PERIOD_END=2026-06-14

KPI_ORGANIZATION=PMG Helpdesk
# production = 2 semaines complètes passées (lun–ven) | current_vs_previous = test
KPI_WEEK_MODE=production

# ── Email automatique (Microsoft Graph sendMail) ─────────────────────────────
GRAPH_SENDER_UPN=ti@pharmaciepmg.ca
EMAIL=ti@pharmaciepmg.ca
EMAIL_SUBJECT=Rapport hebdomadaire KPI - PMG Helpdesk
EMAIL_PREFER_GRAPH=true

# ── Email SMTP (fallback) ────────────────────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TO=
