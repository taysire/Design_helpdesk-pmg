# ── Azure AD app registration (client credentials) ───────────────────────────
# Utilisez MS_* ou AZURE_* — ne commitez JAMAIS ce fichier.
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret

# ── SharePoint / Microsoft Lists ─────────────────────────────────────────────
GRAPH_SITE_HOST=pmgqc.sharepoint.com
GRAPH_SITE_PATH=/sites/Helpdesk
GRAPH_LIST_NAME=Tickets

# ── Email automatique (Microsoft Graph sendMail) ─────────────────────────────
GRAPH_SENDER_UPN=ti@pharmaciepmg.ca
EMAIL=ti@pharmaciepmg.ca
EMAIL_SUBJECT=Rapport hebdomadaire KPI — PMG Helpdesk
EMAIL_PREFER_GRAPH=true

# ── Email SMTP (fallback) ────────────────────────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_TO=
