# Copier vers backend/.env pour dev local (hors Docker)
DATABASE_URL=postgresql+psycopg://pmg:pmg_dev@localhost:5433/pmg_helpdesk
REDIS_URL=redis://localhost:6380/0
API_CORS_ORIGINS=http://127.0.0.1:8888,http://localhost:8888,http://127.0.0.1:5173,http://localhost:5173

# Notifications (mode log = journal en BDD sans envoi réel)
NOTIFICATIONS_ENABLED=true
NOTIFY_EMAIL_MODE=log
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_SLACK_CHANNEL=#ithelp
NOTIFY_JIRA_ENABLED=true
NOTIFY_JIRA_MODE=log
NOTIFY_JIRA_PROJECT=PHARM
NOTIFY_JIRA_CATEGORIES=kroll,pharmacy
