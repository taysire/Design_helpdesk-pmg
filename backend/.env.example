# Copier vers backend/.env pour dev local (hors Docker)
DATABASE_URL=postgresql+psycopg://pmg:pmg_dev@localhost:5433/pmg_helpdesk
REDIS_URL=redis://localhost:6380/0
API_CORS_ORIGINS=http://127.0.0.1:8888,http://localhost:8888,http://127.0.0.1:5173,http://localhost:5173

# Notifications
# NOTIFY_EMAIL_MODE or NOTIFICATIONS_MODE: log (dev) | graph (Microsoft Graph sendMail)
NOTIFICATIONS_ENABLED=true
NOTIFY_EMAIL_MODE=log
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_SLACK_CHANNEL=#ithelp
NOTIFY_JIRA_ENABLED=true
NOTIFY_JIRA_MODE=log
NOTIFY_JIRA_PROJECT=PHARM
NOTIFY_JIRA_CATEGORIES=kroll,pharmacy

# Microsoft Graph email (required when NOTIFY_EMAIL_MODE=graph)
# Aliases also supported: MS_TENANT_ID, MS_CLIENT_ID, MS_CLIENT_SECRET, EMAIL
# Shared file scripts/servicenow_kpi/.env is loaded automatically if backend/.env is absent
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_EMAIL=ti@pharmaciepmg.ca
HELPDESK_PORTAL_URL=http://localhost:8888

# Auth — mode dev par défaut (mock SSO). Pour Entra ID :
AUTH_MODE=dev
AUTH_DEV_USER_ID=me
AUTH_DEV_ROLE=it
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_AUDIENCE=
# ENTRA_API_SCOPE=api://<app-id>/access_as_user
